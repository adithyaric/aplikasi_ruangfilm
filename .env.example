RAJAONGKIR_ORIGIN_DISTRICT_ID=
RAJAONGKIR_ORIGIN_DESTINATION_ID=
RAJAONGKIR_ORIGIN_PIN_POINT=
RAJAONGKIR_API_KEY_SHIPPING_COST=
RAJAONGKIR_API_KEY_SHIPPING_DELIVERY=
RAJAONGKIR_API_KEY_PAYMENT=
RAJAONGKIR_KOMSHIP_ENABLED=false
RAJAONGKIR_DEFAULT_COURIERS=sicepat,jnt,jne,ninja,anteraja,pos,tiki,wahana,lion
RAJAONGKIR_TIMEOUT=20
RAJAONGKIR_RETRY_TIMES=2
RAJAONGKIR_RETRY_SLEEP_MS=250
RAJAONGKIR_SHIPPER_BRAND_NAME=
RAJAONGKIR_SHIPPER_NAME=
